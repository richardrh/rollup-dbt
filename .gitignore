# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv
*.log
*.duckdb
*.sqlite

# Parquet files (generated binary artefacts)
*.parquet

# MkDocs build output
site/
.mkdocs/

.DS_Store


# Local config overrides (tracked defaults live in /config.toml)
# Scoped to repo root only so src/rollup/config.py remains tracked.
/config.py
!/config.toml
/rollup.local.toml
.dual-graph/

# Synthetic test fixture output (regenerated on each pytest run)
tests/data/

# Generated artefacts (regenerable via CLI subcommands)
output/
validation-output/

# Local runtime state
/.tmp/

# Ignore everything inside data/ except section contracts and docs
data/**
!data/**/
!data/**/README.md
!data/**/schema.y*ml
!data/**/validnator*.yml
