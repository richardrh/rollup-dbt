# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv
*.log
*.duckdb
*.sqlite

# Parquet files (generated binary artefacts)
*.parquet

# MkDocs build output
site/
.mkdocs/

.DS_Store

.data/risklink

# Local config (never commit — contains connection strings etc.)
config.py
rollup.local.toml
.dual-graph/

# Synthetic test fixture output (regenerated on each pytest run)
tests/data/
jan-rollup/combined_table

# Generated artefacts (regenerable via CLI subcommands)
output/

# Local runtime state
/.tmp/

# Ignore everything inside data/ except schema.yaml files
data/**
!data/**/
!data/**/schema.y*ml

# Local environment files
.env
.env.*
