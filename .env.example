# Copy this file to .env and fill in your values.
# .env is gitignored — never committed.

# SQL Server target (Windows auth — no username/password needed).
# The pipeline writes one table per Hisco variant alongside the parquet output.
# Leave unset or empty to skip SQL Server and produce parquet only.
ROLLUP_MSSQL_CONN_STR=mssql+pyodbc://your-server/your-database?driver=ODBC+Driver+17+for+SQL+Server&trusted_connection=yes

# Optional path overrides (defaults are relative to the repo root data/ folder)
# ROLLUP_DATA_DIR=/path/to/data
# ROLLUP_OUTPUT_DIR=/path/to/output
# ROLLUP_SEEDS_DIR=/path/to/seeds
# ROLLUP_YLT_VERISK_DIR=/path/to/ylt/verisk
# ROLLUP_YLT_RISKLINK_DIR=/path/to/ylt/risklink
